<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Retiros — Recíbelo</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg,#0f1117);display:flex;min-height:100vh}

:root{--bg:#0f1117;--card:#1a1d27;--card2:#20243a;--border:#2a2d3e;--text:#e8eaf0;--muted:#6b7280;--muted2:#4b5563;--orange:#FF6B35;--azul:#3b82f6;--verde:#22c55e;--rojo:#ef4444;--amarillo:#f59e0b}

/* Sidebar — normalizado con resto de módulos */
.sidebar{width:200px;min-width:200px;background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;min-height:calc(100vh - 56px)}
.nav-section{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;padding:12px 20px 6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:13px;font-weight:600;color:var(--muted2);text-decoration:none;border-left:3px solid transparent;transition:all .15s}
.nav-item:hover{background:rgba(255,255,255,.04);color:var(--text)}
.nav-item.active{color:var(--text);border-left-color:var(--amarillo);background:rgba(245,158,11,.08)}

/* Header global */
header{background:var(--card);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:fixed;top:0;left:0;right:0;z-index:200}
.badge-module{background:rgba(245,158,11,.15);color:var(--amarillo);border-radius:6px;padding:3px 10px;font-size:11px;font-weight:700;letter-spacing:.04em}
.user-chip{display:flex;align-items:center;gap:8px;cursor:pointer;padding:6px 12px;border-radius:8px;border:1px solid var(--border);transition:background .15s}
.user-chip:hover{background:rgba(255,255,255,.05)}
.user-avatar{width:28px;height:28px;border-radius:50%;background:#f59e0b;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff}
.user-name{font-size:12px;color:var(--muted2)}
.app-shell{display:flex;flex:1;overflow:hidden;min-height:0;padding-top:56px}

/* Main */
.main{flex:1;display:flex;flex-direction:column;overflow-y:auto;background:#f0f2f5}
.topbar{background:#fff;border-bottom:1px solid #e0e0e0;padding:10px 24px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;flex-shrink:0}
.file-badge{font-size:12px;color:var(--muted);background:var(--card2);border:1px solid var(--border);padding:4px 10px;border-radius:20px;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* Sections */
.section{padding:32px 24px;display:none;flex-direction:column;align-items:center;justify-content:center;flex:1}
.section.visible{display:flex}
.card-center{background:#fff;border-radius:14px;padding:40px;max-width:560px;width:100%;box-shadow:0 2px 16px rgba(0,0,0,.08);text-align:center}
.card-center h2{font-size:20px;color:#1a1a2e;margin-bottom:8px}
.card-center p{font-size:14px;color:#666;margin-bottom:24px;line-height:1.5}
.url-input{width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;font-size:13px;margin-bottom:10px;font-family:monospace}
.url-input:focus{outline:none;border-color:#1a73e8}
.status-msg{font-size:13px;color:#555;margin-top:10px;min-height:18px}
.error-msg{color:#c62828}

/* Buttons */
.btn-primary{background:#1a73e8;color:#fff;border:none;padding:10px 22px;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600}
.btn-primary:hover{background:#1557b0}
.btn-primary:disabled{opacity:.5;cursor:not-allowed}
.btn-ms{background:#0078d4;color:#fff;border:none;padding:12px 28px;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600;display:flex;align-items:center;gap:10px;margin:0 auto}
.btn-secondary{background:#f5f5f5;color:#333;border:1px solid #ddd;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px}
.btn-sm{padding:5px 12px;font-size:12px;border-radius:5px}

/* Content */
.content{padding:20px 24px;flex:1}
.tabs{display:flex;gap:4px;background:#fff;border-radius:10px;padding:5px;margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,.06);width:fit-content;flex-wrap:wrap}
.tab{padding:8px 18px;border-radius:7px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:600;color:#666;transition:all .2s}
.tab.active{background:#1a73e8;color:#fff}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* KPIs */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:14px;margin-bottom:22px}
.kpi{background:#fff;border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.kpi.blue{border-left:4px solid #1a73e8}.kpi.green{border-left:4px solid #34a853}.kpi.orange{border-left:4px solid #fb8c00}.kpi.purple{border-left:4px solid #9334e8}.kpi.red{border-left:4px solid #e53935}
.kpi-label{font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.kpi-val{font-size:26px;font-weight:700;color:#1a1a2e}
.kpi-sub{font-size:12px;color:#aaa;margin-top:2px}

/* Charts */
.charts-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px;margin-bottom:20px}
.chart-card{background:#fff;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.chart-title{font-size:13px;font-weight:700;color:#333;margin-bottom:12px}
.chart-wrap{position:relative;height:230px}
.chart-wrap.tall{height:300px}

/* Tables */
.tbl-card{background:#fff;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow:auto;margin-bottom:18px}
.tbl-title{font-size:13px;font-weight:700;color:#333;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center}
.tbl{width:100%;border-collapse:collapse;font-size:12px;white-space:nowrap}
.tbl th{background:#f8f9fa;color:#555;font-weight:700;padding:8px 10px;text-align:left;border-bottom:2px solid #e8e8e8;position:sticky;top:0}
.tbl td{padding:7px 10px;border-bottom:1px solid #f0f0f0;color:#333}
.tbl tr:hover td{background:#f5f8ff}
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.b-ok{background:#e8f5e9;color:#2e7d32}.b-warn{background:#fff3e0;color:#e65100}.b-info{background:#e3f2fd;color:#1565c0}.b-red{background:#ffebee;color:#c62828}

/* Filters */
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;align-items:center}
.filter-bar select,.filter-bar input{padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:12px}
.filter-label{font-size:12px;color:#666;font-weight:600}
/* Multi-select flota */
.ms-wrap{position:relative;display:inline-block}
.ms-btn{padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:12px;background:#fff;cursor:pointer;white-space:nowrap;min-width:170px;text-align:left;color:#374151;display:flex;align-items:center;justify-content:space-between;gap:6px}
.ms-btn:hover{border-color:#999}
.ms-dropdown{position:absolute;top:calc(100% + 4px);left:0;z-index:500;background:#fff;border:1px solid #ddd;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,.12);padding:4px 0;max-height:260px;overflow-y:auto;min-width:190px;display:none}
.ms-dropdown.open{display:block}
.ms-dropdown label{display:flex;align-items:center;gap:8px;padding:7px 14px;font-size:12px;cursor:pointer;color:#374151;user-select:none}
.ms-dropdown label:hover{background:#f3f4f6}
.ms-dropdown label.ms-all{border-bottom:1px solid #e5e7eb;font-weight:600;color:#111}
.ms-dropdown input[type=checkbox]{cursor:pointer;accent-color:#1a73e8;width:14px;height:14px}

/* Loading */
.spinner{width:36px;height:36px;border:4px solid #e0e0e0;border-top-color:#1a73e8;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── LOGIN SCREEN ─────────────────────────────────────────── */
#login-screen{display:none;align-items:center;justify-content:center;min-height:100vh;background:#f0f2f5;width:100%}
.login-card{background:#1e1e2e;border:1px solid #333;border-radius:16px;padding:40px 36px;text-align:center;width:340px}
.login-card img{height:36px;margin-bottom:20px}
.login-card h2{font-size:18px;font-weight:700;color:#fff;margin-bottom:6px}
.login-card p{color:#9ca3af;font-size:13px;margin-bottom:24px}
.btn-fb-login{width:100%;padding:11px;border-radius:8px;border:1px solid #333;background:#2d2d4e;color:#fff;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:10px;transition:background .15s}
.btn-fb-login:hover{background:#3d3d6e}
.login-err{color:#f87171;font-size:12px;margin-top:10px;min-height:18px}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div id="login-screen">
  <div class="login-card">
    <img src="/logo.png" alt="Recíbelo">
    <h2>🚛 Retiros</h2>
    <p>Inicia sesión para acceder al módulo</p>
    <button class="btn-fb-login" onclick="window.fbSignInMS()">
      <svg width="16" height="16" viewBox="0 0 21 21" fill="none"><rect x="1" y="1" width="9" height="9" fill="#f25022"/><rect x="11" y="1" width="9" height="9" fill="#7fba00"/><rect x="1" y="11" width="9" height="9" fill="#00a4ef"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
      Iniciar con Microsoft
    </button>
    <button class="btn-fb-login" onclick="window.fbSignInGoogle()">
      <svg width="16" height="16" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.8 2.4 30.3 0 24 0 14.6 0 6.6 5.5 2.7 13.5l7.9 6.1C12.5 13.3 17.8 9.5 24 9.5z"/><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 7.1-10.1 7.1-17z"/><path fill="#FBBC05" d="M10.6 28.4A14.5 14.5 0 0 1 9.5 24c0-1.5.2-3 .6-4.4l-7.9-6.1A23.9 23.9 0 0 0 0 24c0 3.9.9 7.5 2.7 10.7l7.9-6.3z"/><path fill="#34A853" d="M24 48c6.5 0 11.9-2.1 15.9-5.8l-7.5-5.8c-2.2 1.5-5 2.3-8.4 2.3-6.2 0-11.5-4.2-13.4-9.9l-7.9 6.1C6.5 42.4 14.6 48 24 48z"/></svg>
      Iniciar con Google
    </button>
    <div class="login-err" id="login-error"></div>
  </div>
</div>

<div id="app" style="display:none;flex-direction:column;flex:1">

  <!-- Header: ancho completo sobre sidebar + contenido -->
  <header>
    <div style="display:flex;align-items:center;gap:10px">
      <img src="/recibelo.cl2.png" alt="Recibelo" style="height:28px">
      <span class="badge-module">🚛 Retiros</span>
    </div>
    <div style="display:flex;align-items:center;gap:14px">
      <span id="header-file" style="font-size:12px;color:var(--muted)">Sin datos cargados</span>
      <div class="user-chip" onclick="cerrarSesion()">
        <div class="user-avatar" id="user-avatar">?</div>
        <span class="user-name" id="user-name"></span>
        <span style="font-size:11px;color:var(--muted);margin-left:2px">salir</span>
      </div>
    </div>
  </header>

  <div class="app-shell">
<nav class="sidebar">
  <div class="nav-section">Módulos</div>
  <a id="nav-controller"   href="/"                class="nav-item" style="display:none">📋 Controller</a>
  <a id="nav-asistencia"   href="/asistencia_ruta" class="nav-item" style="display:none">🚚 Asistencia Ruta</a>
  <a id="nav-operacional"  href="/operacional"     class="nav-item" style="display:none">📦 Operacional</a>
  <a id="nav-finanzas"     href="/finanzas"        class="nav-item" style="display:none">💰 Finanzas</a>
  <a id="nav-sla"          href="/sla"             class="nav-item" style="display:none">📊 SLA CX</a>
  <a id="nav-incidencias"  href="/incidencias"     class="nav-item" style="display:none">📊 Incidencias</a>
  <a id="nav-retiros"      href="/retiros"         class="nav-item active">🚛 Retiros</a>
  <div class="nav-recursos" style="margin-top:auto;border-top:1px solid var(--border);padding-top:4px">
    <div class="nav-section">Recursos</div>
    <a href="/falabella/" target="_blank" rel="noopener" class="nav-item" style="font-size:12px;opacity:.8">🟢 Falabella Directo <span style="font-size:10px;margin-left:auto;opacity:.5">&#8599;</span></a>
  </div>
</nav>

<!-- MAIN -->
<div class="main">

  <!-- Topbar operacional -->
  <div class="topbar" id="topbar" style="display:none">
    <span class="file-badge" id="file-badge">Sin archivo</span>
    <button class="btn-secondary btn-sm" onclick="recargarDatos()" title="Recargar datos del mismo archivo">🔄 Actualizar</button>
    <button class="btn-secondary btn-sm" onclick="showSection('load')">📁 Cambiar archivo</button>
    <button class="btn-primary btn-sm" onclick="cerrarMes()" id="btn-cerrar-mes" style="margin-left:auto;background:#16a34a;color:#fff;border-color:#16a34a">📅 Cerrar mes</button>
  </div>

  <!-- SECCIÓN: Microsoft Login -->
  <div class="section visible" id="sec-mslogin">
    <div class="card-center">
      <div style="font-size:48px;margin-bottom:16px">🔑</div>
      <h2>Conectar Microsoft 365</h2>
      <p>Para acceder a los archivos de retiros en SharePoint, inicia sesión con tu cuenta corporativa de Recíbelo.</p>
      <button class="btn-ms" onclick="loginMS()">
        <svg width="20" height="20" viewBox="0 0 21 21" fill="none"><rect width="10" height="10" fill="#F25022"/><rect x="11" width="10" height="10" fill="#7FBA00"/><rect y="11" width="10" height="10" fill="#00A4EF"/><rect x="11" y="11" width="10" height="10" fill="#FFB900"/></svg>
        Iniciar sesión con Microsoft
      </button>
      <div class="status-msg" id="ms-status"></div>
    </div>
  </div>

  <!-- SECCIÓN: Cargar archivo -->
  <div class="section" id="sec-load">
    <div class="card-center">
      <div style="font-size:48px;margin-bottom:16px">📁</div>
      <h2>Cargar archivo de Retiros</h2>
      <p>Pega el link del Excel de SharePoint correspondiente al mes que quieres analizar.<br>
      El archivo debe tener la hoja <strong>"RETIROS SDD"</strong>.</p>
      <input id="share-url" class="url-input" type="text" placeholder="https://recibelospa.sharepoint.com/:x:/r/sites/..." />
      <button class="btn-primary" onclick="loadFile()" style="width:100%">▶ Cargar datos</button>
      <div class="status-msg" id="load-status"></div>
    </div>
  </div>

  <!-- SECCIÓN: Cargando -->
  <div class="section" id="sec-loading">
    <div class="card-center">
      <div class="spinner"></div>
      <h2>Cargando datos...</h2>
      <p class="status-msg" id="loading-msg">Conectando con SharePoint</p>
    </div>
  </div>

  <!-- SECCIÓN: Datos -->
  <div class="section" id="sec-data" style="align-items:stretch;justify-content:flex-start;padding:20px 24px">

    <!-- Filtros globales -->
    <div class="filter-bar" id="global-filters">
      <span class="filter-label">Filtrar:</span>
      <select id="f-cliente" onchange="applyFilters()"><option value="">Todos los clientes</option></select>
      <select id="f-conductor" onchange="applyFilters()"><option value="">Todos los conductores</option></select>
      <div class="ms-wrap" id="flota-wrap">
        <button class="ms-btn" id="flota-btn" onclick="toggleFlotaDD(event)">
          <span id="flota-label">— Todas las flotas</span><span>▾</span>
        </button>
        <div class="ms-dropdown" id="flota-dd">
          <label class="ms-all"><input type="checkbox" id="flota-all" onchange="onFlotaAllChange(this)"> Todas las flotas</label>
        </div>
      </div>
      <select id="f-comuna" onchange="applyFilters()"><option value="">Todas las comunas</option></select>
      <button class="btn-secondary btn-sm" onclick="clearFilters()">✕ Limpiar</button>
      <span id="filter-count" style="font-size:12px;color:#888"></span>
    </div>

    <!-- Tabs -->
    <div class="tabs">
      <button class="tab active" onclick="showTab('dashboard')">📊 Dashboard</button>
      <button class="tab" onclick="showTab('chofer')">🚗 Por Chofer</button>
      <button class="tab" onclick="showTab('comunas')">🏙️ Comunas</button>
      <button class="tab" onclick="showTab('clientes')">🏢 Clientes</button>
      <button class="tab" onclick="showTab('tiempos')">⏱️ Tiempos</button>
      <button class="tab" onclick="showTab('detalle')">📋 Detalle</button>
      <button class="tab" onclick="showTab('cobros')">💸 Cobros</button>
      <button class="tab" onclick="showTab('historial')">📅 Historial</button>
    </div>

    <!-- Tab: Dashboard -->
    <div class="tab-panel active" id="tab-dashboard">
      <div class="kpi-grid" id="kpis"></div>
      <div class="charts-grid" id="charts-row1"></div>
      <div class="charts-grid" id="charts-row2"></div>
    </div>

    <!-- Tab: Por Chofer -->
    <div class="tab-panel" id="tab-chofer">
      <div class="charts-grid">
        <div class="chart-card" style="grid-column:span 2">
          <div class="chart-title">Tiempo promedio de tránsito por conductor (Retiro → Bodega)</div>
          <div class="chart-wrap tall"><canvas id="ch-chofer-tiempo"></canvas></div>
        </div>
      </div>
      <div class="tbl-card">
        <div class="tbl-title">Resumen por Conductor</div>
        <table class="tbl" id="tbl-chofer"></table>
      </div>
    </div>

    <!-- Tab: Comunas -->
    <div class="tab-panel" id="tab-comunas">
      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-title">Pedidos retirados por comuna</div>
          <div class="chart-wrap tall"><canvas id="ch-comuni-paq"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">Tiempo promedio tránsito por comuna</div>
          <div class="chart-wrap tall"><canvas id="ch-comuni-tiempo"></canvas></div>
        </div>
      </div>
      <div class="tbl-card">
        <div class="tbl-title">Resumen por Comuna</div>
        <table class="tbl" id="tbl-comunas"></table>
      </div>
    </div>


    <!-- Tab: Clientes -->
    <div class="tab-panel" id="tab-clientes">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;flex-wrap:wrap">
        <h3 style="font-size:15px;font-weight:700;color:#1a1a2e;margin:0">Análisis por cliente</h3>
        <div style="display:flex;gap:8px;margin-left:auto;flex-wrap:wrap">
          <button class="btn-secondary btn-sm" onclick="sortClientes('paquetes','desc')" id="sort-paq-desc">📦 Mayor paquetería</button>
          <button class="btn-secondary btn-sm" onclick="sortClientes('paquetes','asc')"  id="sort-paq-asc">📦 Menor paquetería</button>
          <button class="btn-secondary btn-sm" onclick="sortClientes('costo_retiro','desc')" id="sort-cost-desc">💸 Mayor costo/retiro</button>
          <button class="btn-secondary btn-sm" onclick="sortClientes('tardios','desc')" id="sort-tard-desc">⏰ Más tardíos</button>
        </div>
      </div>
      <!-- KPI cards rápidos -->
      <div id="cli-kpis" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:16px"></div>
      <!-- Tabla -->
      <div style="overflow-x:auto">
        <table class="tbl" id="tbl-clientes" style="min-width:900px">
          <thead><tr>
            <th style="text-align:left">Cliente</th>
            <th onclick="sortClientes('retiros','desc')" style="cursor:pointer" title="Ordenar">Retiros ↕</th>
            <th onclick="sortClientes('paquetes','desc')" style="cursor:pointer" title="Ordenar">Paquetes ↕</th>
            <th onclick="sortClientes('paq_por_retiro','asc')" style="cursor:pointer" title="Paquetes promedio por retiro">Paq/Retiro ↕</th>
            <th onclick="sortClientes('tarifa','desc')" style="cursor:pointer" title="Ordenar">Tarifa Total ↕</th>
            <th onclick="sortClientes('costo_retiro','desc')" style="cursor:pointer" title="Tarifa ÷ Retiros — mayor = menos eficiente">Costo/Retiro ↕</th>
            <th onclick="sortClientes('transito','asc')" style="cursor:pointer" title="Ordenar">Tránsito Prom. ↕</th>
            <th onclick="sortClientes('tardios','desc')" style="cursor:pointer" title="Ordenar">Tardíos ↕</th>
          </tr></thead>
          <tbody id="tbody-clientes"></tbody>
        </table>
      </div>
      <p style="font-size:11px;color:#9ca3af;margin-top:10px">
        💸 <b>Costo/Retiro</b> = tarifa total ÷ número de retiros. Clientes con muchos retiros pero pocos paquetes tienen costo/retiro alto — candidatos a renegociar o discontinuar.
      </p>
    </div>
    <!-- Tab: Tiempos -->
    <div class="tab-panel" id="tab-tiempos">
      <div class="kpi-grid" id="kpis-tiempos"></div>
      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-title">Distribución de tiempos de tránsito (min)</div>
          <div class="chart-wrap"><canvas id="ch-dist-transito"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">Conductores que llegaron al CD después de las 15:00</div>
          <div class="chart-wrap"><canvas id="ch-tardios"></canvas></div>
        </div>
      </div>
      <div class="tbl-card">
        <div class="tbl-title">⚠️ Retiros fuera de horario de corte</div>
        <table class="tbl" id="tbl-tardios"></table>
      </div>
    </div>

    <!-- Tab: Detalle -->
    <div class="tab-panel" id="tab-detalle">
      <div class="filter-bar">
        <span class="filter-label">Buscar:</span>
        <input id="f-search" type="text" placeholder="Cliente, conductor, nota..." onkeyup="applyFilters()" style="min-width:200px">
      </div>
      <div class="tbl-card">
        <div class="tbl-title">
          <span id="det-count">— registros</span>
          <button class="btn-secondary btn-sm" onclick="exportCSV()">⬇ Exportar CSV</button>
        </div>
        <table class="tbl" id="tbl-detalle">
          <thead><tr>
            <th>Fecha</th><th>Cliente</th><th>Comuna</th><th>Conductor</th>
            <th>Q Repor.</th><th>Hora Repor.</th><th>Q. op</th><th>Hora Llegada</th>
            <th>Tránsito</th><th>Tarifa</th><th>Flota</th><th>Notas</th><th></th>
          </tr></thead>
          <tbody id="det-tbody"></tbody>
        </table>
      </div>
    </div>


    <!-- Tab: Cobros -->
    <div class="tab-panel" id="tab-cobros">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
        <h3 style="font-size:15px;font-weight:700;color:#1a1a2e">💸 Viajes en vacío — Cobros</h3>
        <button class="btn-secondary btn-sm" onclick="renderCobros()">🔄 Actualizar</button>
      </div>
      <div id="cobros-container"></div>
    </div>

    <!-- Tab: Historial -->
    <div class="tab-panel" id="tab-historial">
      <div style="margin-bottom:16px;display:flex;align-items:center;gap:12px">
        <h3 style="font-size:15px;font-weight:700;color:#1a1a2e">Resúmenes mensuales guardados</h3>
        <button class="btn-secondary btn-sm" onclick="cargarHistorial()">🔄 Recargar</button>
      </div>
      <div id="historial-container">
        <p style="color:#888;font-size:13px">Cargando historial...</p>
      </div>
    </div>
  </div><!-- /sec-data -->
</div><!-- /main -->
  </div><!-- /app-shell -->

<script type="module">
import * as msal from "https://esm.sh/@azure/msal-browser@2.38.3";
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
import { getFirestore, doc, getDoc, setDoc, addDoc, collection, getDocs, query, orderBy, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

// ─── CONFIG ─────────────────────────────────────────────────────────────────
const CLIENT_ID  = '166dea1f-205e-4e2d-826b-93e47e2c555b';
const TENANT_ID  = 'd077d4c8-2f55-4f6c-a8fc-6d31129c4dc2';
const SHEET_NAME = 'RETIROS SDD';
const GRAPH      = 'https://graph.microsoft.com/v1.0';

const FB_CONFIG = {
  apiKey:"AIzaSyBXzxAnZZicHX-VoQDvcJ0rHqP3_pyu0-U",
  authDomain:"proyectos-ctrl.firebaseapp.com",
  projectId:"proyectos-ctrl",
  storageBucket:"proyectos-ctrl.firebasestorage.app",
  messagingSenderId:"87976835637",
  appId:"1:87976835637:web:50ccffcbccd8e550c34f7c"
};

// ─── FIREBASE AUTH ───────────────────────────────────────────────────────────
const fbApp  = initializeApp(FB_CONFIG);
const fbAuth = getAuth(fbApp);
const db     = getFirestore(fbApp);
let currentUser = null;
window._currentUser = null;

onAuthStateChanged(fbAuth, async user => {
  if (!user) {
    document.getElementById('login-screen').style.display = 'flex';
    document.getElementById('app').style.display = 'none';
    return;
  }
  currentUser = user;
    window._currentUser = user;
  let roles = [];
  try {
    const snap = await getDoc(doc(db,'config','acceso'));
    if (snap.exists()) {
      const data = snap.data();
      const rolesMap = data.roles || data; // soporta ambas estructuras
      const emailLower = (user.email || '').toLowerCase();
      const key = Object.keys(rolesMap).find(k => k.toLowerCase() === emailLower);
      roles = key ? (rolesMap[key] || []) : [];
    }
  } catch(e) {
    // Firestore bloqueado (ej: ad blocker) — permitir acceso como hacen los otros módulos
    console.warn('Firestore bloqueado, acceso permitido sin verificar rol:', e.message);
    roles = ['controller']; // fallback permisivo
  }
  const ok = roles.includes('retiros') || roles.includes('controller') || roles.includes('admin');
  if (!ok) { window.location.href = '/'; return; }
  const _name = user.displayName || user.email || '?';
  const _avatar = document.getElementById('user-avatar');
  const _uname  = document.getElementById('user-name');
  if (_avatar) _avatar.textContent = _name.charAt(0).toUpperCase();
  if (_uname)  _uname.textContent  = _name;
  showNavItems(roles);
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  initModule();
});

function showNavItems(roles) {
  const map = {
    'nav-controller':  r => r.includes('controller')||r.includes('admin'),
    'nav-sla':         r => r.includes('sla')||r.includes('controller')||r.includes('admin'),
    'nav-operacional': r => r.includes('operacional')||r.includes('controller')||r.includes('admin'),
    'nav-finanzas':    r => r.includes('finanzas')||r.includes('controller')||r.includes('admin'),
    'nav-asistencia':  r => r.includes('asistencia')||r.includes('controller')||r.includes('admin'),
    'nav-incidencias': r => r.includes('incidencias')||r.includes('controller')||r.includes('admin'),
    'nav-retiros':     r => r.includes('retiros')||r.includes('controller')||r.includes('admin'),
  };
  for (const [id, check] of Object.entries(map)) {
    const el = document.getElementById(id);
    if (el && check(roles)) { el.style.display='flex'; }
  }
}


// ── FIREBASE LOGIN FUNCTIONS ──────────────────────────────────────────────────
(function() {
  const { OAuthProvider, GoogleAuthProvider, signInWithPopup } = window.__fbAuthExports || {};
  // Se importan en el módulo principal — se exponen aquí como helpers
})();

window.fbSignInMS = async function() {
  const errEl = document.getElementById('login-error');
  if (errEl) errEl.textContent = '';
  try {
    const { OAuthProvider, signInWithPopup } = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js');
    const prov = new OAuthProvider('microsoft.com');
    prov.setCustomParameters({ tenant: 'recibelo.cl' });
    await signInWithPopup(fbAuth, prov);
  } catch(e) {
    if (e.code !== 'auth/cancelled-popup-request' && e.code !== 'auth/popup-closed-by-user') {
      if (errEl) errEl.textContent = e.message;
    }
  }
};

window.fbSignInGoogle = async function() {
  const errEl = document.getElementById('login-error');
  if (errEl) errEl.textContent = '';
  try {
    const { GoogleAuthProvider, signInWithPopup } = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js');
    const prov = new GoogleAuthProvider();
    await signInWithPopup(fbAuth, prov);
  } catch(e) {
    if (e.code !== 'auth/cancelled-popup-request' && e.code !== 'auth/popup-closed-by-user') {
      if (errEl) errEl.textContent = e.message;
    }
  }
};


// ─── ACTUALIZAR (recarga desde localStorage URL) ─────────────────────────────
window.recargarDatos = async () => {
  const url = localStorage.getItem('retiros_url');
  if (!url) { showSection('load'); return; }
  document.getElementById('share-url').value = url;
  await window.loadFile(false);
};

// ─── CERRAR MES ───────────────────────────────────────────────────────────────
window.cerrarMes = async () => {
  if (!ROWS.length) { alert('No hay datos cargados.'); return; }
  if (!currentUser) { alert('Sin sesión activa.'); return; }

  const periodo = (() => {
    // Detectar período desde los datos
    const fechas = ROWS.map(r => r.fechaRetiro).filter(Boolean);
    if (!fechas.length) return new Date().toISOString().slice(0,7);
    fechas.sort();
    const d = new Date(fechas[Math.floor(fechas.length/2)]);
    return isNaN(d) ? new Date().toISOString().slice(0,7)
                    : `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
  })();

  if (!confirm(`¿Cerrar mes ${periodo}? Se guardará el resumen en Firebase.`)) return;

  // KPIs globales
  const totalRetiros  = ROWS.length;
  const totalPaquetes = ROWS.reduce((s,r) => s + (r.qOp||0), 0);
  const transitosValidos = ROWS.filter(r => r.transitoMin != null && r.transitoMin > 0 && r.transitoMin < 600);
  const transitoProm  = transitosValidos.length
    ? Math.round(transitosValidos.reduce((s,r) => s + r.transitoMin, 0) / transitosValidos.length)
    : null;
  const tardios  = ROWS.filter(r => r.llegadaTardio);   // llegada post 15:00
  const criticos = ROWS.filter(r => r.llegadaCritica); // llegada post 15:15
  const tardiosPct = totalRetiros ? Math.round(tardios.length / totalRetiros * 1000) / 10 : 0;
  const viajesVacio = getViajesVacio();

  // Por chofer
  const chofMap = {};
  for (const r of ROWS) {
    const k = r.conductor || 'Sin asignar';
    if (!chofMap[k]) chofMap[k] = { nombre:k, retiros:0, paquetes:0, transitoSum:0, transitoCnt:0, tardios:0 };
    chofMap[k].retiros++;
    chofMap[k].paquetes += (r.qOp||0);
    if (r.transitoMin != null && r.transitoMin > 0 && r.transitoMin < 600) {
      chofMap[k].transitoSum += r.transitoMin;
      chofMap[k].transitoCnt++;
    }
    if (r.llegadaTardio)  chofMap[k].tardios++;   // post 15:00
    if (r.llegadaCritica) chofMap[k].criticos = (chofMap[k].criticos||0) + 1; // post 15:15
  }
  const porChofer = Object.values(chofMap).map(c => ({
    nombre:       c.nombre,
    retiros:      c.retiros,
    paquetes:     c.paquetes,
    transito_prom: c.transitoCnt ? Math.round(c.transitoSum/c.transitoCnt) : null,
    tardios:      c.tardios,
    tardios_pct:  c.retiros ? Math.round(c.tardios/c.retiros*1000)/10 : 0
  })).sort((a,b) => b.tardios - a.tardios);

  // Por cliente
  const cliMap = {};
  for (const r of ROWS) {
    const k = r.cliente || 'Sin cliente';
    if (!cliMap[k]) cliMap[k] = { nombre:k, retiros:0, paquetes:0 };
    cliMap[k].retiros++;
    cliMap[k].paquetes += (r.qOp||0);
  }
  const porCliente = Object.values(cliMap).sort((a,b) => b.retiros - a.retiros).slice(0,20);

  // Por flota
  const flotaMap = {};
  for (const r of ROWS) {
    const k = r.flota || 'Sin flota';
    if (!flotaMap[k]) flotaMap[k] = { flota:k, retiros:0 };
    flotaMap[k].retiros++;
  }
  const porFlota = Object.values(flotaMap).sort((a,b) => b.retiros - a.retiros);

  const resumen = {
    periodo,
    fecha_cierre:   new Date().toISOString(),
    cerrado_por:    currentUser.email,
    archivo:        document.getElementById('file-badge').textContent,
    total_retiros:  totalRetiros,
    total_paquetes: totalPaquetes,
    transito_prom_min: transitoProm,
    viajes_vacio:        viajesVacio.length,
    monto_vacio_estimado: viajesVacio.reduce((s,r) => s + (r.tarifa||0), 0),
    tardios_count:  tardios.length,
    tardios_pct:    tardiosPct,
    por_chofer:     porChofer,
    por_cliente:    porCliente,
    por_flota:      porFlota
  };

  try {
    await setDoc(doc(db, 'retiros_resumen', periodo), resumen);
    alert(`✅ Mes ${periodo} cerrado y guardado correctamente.`);
    // Cambiar al tab historial
    showTab('historial');
    await cargarHistorial();
  } catch(e) {
    alert('❌ Error guardando: ' + e.message);
  }
};

// ─── CARGAR HISTORIAL ────────────────────────────────────────────────────────
window.cargarHistorial = async () => {
  const cont = document.getElementById('historial-container');
  if (!cont) return;
  cont.innerHTML = '<p style="color:#888;font-size:13px">Cargando...</p>';
  try {
    const snap = await getDocs(query(collection(db,'retiros_resumen'), orderBy('periodo','desc')));
    if (snap.empty) {
      cont.innerHTML = '<p style="color:#888;font-size:13px">No hay meses cerrados aún. Usa "📅 Cerrar mes" para guardar el primer resumen.</p>';
      return;
    }
    const meses = snap.docs.map(d => d.data());
    cont.innerHTML = meses.map(m => {
      const topAtrasados = (m.por_chofer||[]).filter(c=>c.tardios>0).slice(0,5);
      return `<div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:20px;margin-bottom:16px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
          <h3 style="font-size:16px;font-weight:700;color:#1a1a2e;margin:0">${m.periodo}</h3>
          <span style="font-size:11px;color:#888">Cerrado por ${m.cerrado_por} · ${new Date(m.fecha_cierre).toLocaleDateString('es-CL')}</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:16px">
          ${kpiCard('Retiros', m.total_retiros)}
          ${kpiCard('Paquetes', m.total_paquetes)}
          ${kpiCard('Tránsito prom.', m.transito_prom_min != null ? m.transito_prom_min + ' min' : '—')}
          ${kpiCard('Post 15:00', m.tardios_count + ' (' + m.tardios_pct + '%)') + kpiCard('Post 15:15 🔴', m.criticos_count ?? '—') + kpiCard('Viajes vacíos', (m.viajes_vacio ?? '—') + (m.monto_vacio_estimado ? ' · $' + m.monto_vacio_estimado.toLocaleString('es-CL') : ''))}
        </div>
        ${topAtrasados.length ? `
        <div style="margin-top:8px">
          <p style="font-size:12px;font-weight:600;color:#374151;margin-bottom:8px">🕐 Choferes con más atrasos</p>
          <table style="width:100%;border-collapse:collapse;font-size:12px">
            <thead><tr style="background:#f9fafb"><th style="padding:6px 8px;text-align:left;border-bottom:1px solid #e5e7eb">Chofer</th><th style="padding:6px 8px;text-align:right;border-bottom:1px solid #e5e7eb">Atrasos</th><th style="padding:6px 8px;text-align:right;border-bottom:1px solid #e5e7eb">%</th><th style="padding:6px 8px;text-align:right;border-bottom:1px solid #e5e7eb">Tránsito prom.</th></tr></thead>
            <tbody>${topAtrasados.map(c=>`<tr><td style="padding:5px 8px;border-bottom:1px solid #f3f4f6">${c.nombre}</td><td style="padding:5px 8px;text-align:right;border-bottom:1px solid #f3f4f6;color:#dc2626;font-weight:600">${c.tardios}</td><td style="padding:5px 8px;text-align:right;border-bottom:1px solid #f3f4f6;color:#dc2626">${c.tardios_pct}%</td><td style="padding:5px 8px;text-align:right;border-bottom:1px solid #f3f4f6;color:#6b7280">${c.transito_prom||'—'} min</td></tr>`).join('')}</tbody>
          </table>
        </div>` : ''}
      </div>`;
    }).join('');
  } catch(e) {
    cont.innerHTML = '<p style="color:#dc2626;font-size:13px">Error cargando historial: ' + e.message + '</p>';
  }
};

function kpiCard(label, value) {
  return `<div style="background:#f8faff;border:1px solid #dbe9ff;border-radius:8px;padding:12px;text-align:center">
    <div style="font-size:18px;font-weight:700;color:#1a1a2e">${value ?? '—'}</div>
    <div style="font-size:11px;color:#6b7280;margin-top:2px">${label}</div>
  </div>`;
}


window.cerrarSesion = () => signOut(fbAuth).then(() => window.location.href='/');

// ─── MSAL ────────────────────────────────────────────────────────────────────
let msalInstance = null;
let msAccount    = null;

async function initMSAL() {
  msalInstance = new msal.PublicClientApplication({
    auth: { clientId: CLIENT_ID, authority: `https://login.microsoftonline.com/${TENANT_ID}`, redirectUri: window.location.origin + '/retiros' },
    cache: { cacheLocation: 'sessionStorage' }
  });
  await msalInstance.initialize();
  const accounts = msalInstance.getAllAccounts();
  if (accounts.length > 0) { msAccount = accounts[0]; return true; }
  return false;
}

window.loginMS = async () => {
  const statusEl = document.getElementById('ms-status');
  if (statusEl) statusEl.textContent = 'Iniciando…';
  try {
    // Lazy init: si initMSAL aún no corrió, correrlo ahora
    if (!msalInstance) {
      if (statusEl) statusEl.textContent = 'Inicializando MSAL…';
      await initMSAL();
    }
    if (statusEl) statusEl.textContent = 'Abriendo ventana de Microsoft…';
    const res = await msalInstance.loginPopup({ scopes: ['Files.Read.All','Sites.Read.All'] });
    msAccount = res.account;
    if (statusEl) statusEl.textContent = '';
    showSection('load');
  } catch(e) {
    const msg = e.message || String(e);
    if (statusEl) statusEl.textContent = '❌ ' + msg;
    console.error('loginMS error:', e);
  }
};

async function getToken() {
  const res = await msalInstance.acquireTokenSilent({
    scopes: ['Files.Read.All','Sites.Read.All'],
    account: msAccount
  });
  return res.accessToken;
}

async function gget(endpoint) {
  const tok = await getToken();
  const res = await fetch(GRAPH + endpoint, { headers: { Authorization: 'Bearer ' + tok } });
  if (!res.ok) throw new Error(`Graph ${res.status}: ${await res.text()}`);
  return res.json();
}

// ─── INIT MODULE ─────────────────────────────────────────────────────────────
async function initModule() {
  await initMSAL();
  const hasMs = msalInstance.getAllAccounts().length > 0;
  if (!hasMs) { showSection('mslogin'); return; }
  msAccount = msalInstance.getAllAccounts()[0];
  // Restore URL from session
  const savedUrl = localStorage.getItem('retiros_url');
  if (savedUrl) {
    document.getElementById('share-url').value = savedUrl;
    await loadFile(true);
  } else {
    showSection('load');
  }
}

// ─── LOAD FILE ───────────────────────────────────────────────────────────────
let ROWS = [], RAW_ROWS = [];
window.AVISAN_ROWS = []; // filas sin viaje real — excluidas del análisis
window.TOTAL_ROWS  = []; // filas de total diario (conductor Y) — suma autorizada

// Valores en columna Conductor que NO representan un viaje real de retiro.
// Añadir aquí si aparecen nuevos casos.
const NON_TRIP = [
  'avisan retiro',   // solo van cuando avisan — si sigue así, no fue nadie
  'sin retiros',     // no se realizan retiros a este cliente
  'congelado',       // cliente con factura impaga — sin retiro hasta que pague
  'por asignar',     // aún sin conductor asignado
  'sin operacion',   // sin operación
  'sin operación',   // variante con tilde
  'por puerta',      // dust / progaming — lo pasan por la puerta compartida
  'lo traen ellos',  // el cliente lleva la paquetería directamente
  'solo jueves',     // cliente con visita solo los jueves — si no es jueves, no se cobra
  'sin retiro sameday', // sin retiro en modalidad sameday
];

// Normaliza comunas que son alias de la misma zona geográfica.
// Agregar aquí si aparecen nuevas variantes.
function normalizarComuna(c) {
  if (!c) return c;
  const upper = c.trim().toUpperCase();
  if (upper.startsWith('RENCA')) return 'RENCA'; // RENCA (Patio Panal) → RENCA
  return c.trim().toUpperCase();
}

function isNonTrip(conductor) {
  if (!conductor) return false;
  const c = conductor.trim().toLowerCase();
  return NON_TRIP.some(t => c.includes(t));
}

window.loadFile = async (silent = false) => {
  const url = document.getElementById('share-url').value.trim();
  if (!url) { document.getElementById('load-status').textContent = '⚠️ Pega el link del archivo.'; return; }

  showSection('loading');
  setLoadingMsg('Conectando con SharePoint...');

  try {
    // Encode sharing URL → Microsoft Graph shares endpoint
    const encoded = 'u!' + btoa(unescape(encodeURIComponent(url)))
      .replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');

    setLoadingMsg('Resolviendo archivo...');
    const item = await gget(`/shares/${encoded}/driveItem`);
    const driveId = item.parentReference.driveId;
    const itemId  = item.id;

    setLoadingMsg('Detectando rango de datos...');

    // Helper: número de columna → letra (1=A, 26=Z, 27=AA ...)
    function colToLetter(n) {
      let s = '';
      while (n > 0) { n--; s = String.fromCharCode(65 + (n % 26)) + s; n = Math.floor(n / 26); }
      return s;
    }

    // Paso 1: leer solo columna A para encontrar última fila con dato real
    // Excel puede reportar millones de filas "usadas" por formato vacío
    setLoadingMsg('Buscando última fila con datos...');
    const PROBE_MAX = 50000; // máximo para archivos con mucha actividad
    const LAST_COL  = 'AZ';  // columna final suficiente para cualquier layout

    // Leer en chunks de 1000 filas, parar al primer chunk completamente vacío
    const CHUNK = 1000;
    let allValues  = [];
    let foundHeader = false;

    for (let start = 1; start <= PROBE_MAX; start += CHUNK) {
      const end  = Math.min(start + CHUNK - 1, PROBE_MAX);
      setLoadingMsg(`Leyendo filas ${start}–${end}...`);
      const addr  = `A${start}:${LAST_COL}${end}`;
      const chunk = await gget(
        `/drives/${driveId}/items/${itemId}/workbook/worksheets/${encodeURIComponent(SHEET_NAME)}/range(address='${addr}')`
      );
      const rows = chunk.values || [];

      // Detectar si el chunk es completamente vacío (pasamos el final real de los datos)
      const isEmpty = rows.every(row => row.every(cell => cell === null || cell === '' || cell === 0));
      if (isEmpty && allValues.length > 0) {
        setLoadingMsg(`Fin de datos detectado en fila ${start - 1}. Procesando...`);
        break;
      }

      allValues = allValues.concat(rows);
    }

    parseData(allValues, item.name);
    localStorage.setItem('retiros_url', url);

    document.getElementById('file-badge').textContent = item.name;
      const _hf = document.getElementById('header-file');
      if (_hf) _hf.textContent = 'Cargado: ' + item.name;
    document.getElementById('topbar').style.display = 'flex';

    showSection('data');
    renderAll();

  } catch(e) {
    const errEl = document.getElementById(silent ? 'load-status' : 'load-status');
    document.getElementById('load-status').textContent = '❌ ' + (e.message.includes('404') ? 'Hoja "RETIROS SDD" no encontrada en el archivo.' : e.message);
    showSection('load');
  }
};

// ─── PARSE DATA ──────────────────────────────────────────────────────────────
function parseData(values, fname) {
  if (!values || values.length < 2) { RAW_ROWS = []; ROWS = []; return; }

  // Find header row (contains "Fecha")
  let hIdx = 0;
  for (let i = 0; i < Math.min(5, values.length); i++) {
    if (values[i].some(c => c && c.toString().toLowerCase().includes('fecha'))) { hIdx = i; break; }
  }

  const headers = values[hIdx].map(h => h ? h.toString().toLowerCase().trim() : '');

  const ci = name => {
    const n = name.toLowerCase();
    return headers.findIndex(h => h.includes(n));
  };

  const H = {
    fecha:     ci('fecha'),
    hrCorte:   ci('hr corte') >= 0 ? ci('hr corte') : ci('corte'),
    cliente:   ci('cliente'),
    comuna:    ci('comuna'),
    conductor: ci('conductor'),
    qRepor:    ci('q repor') >= 0 ? ci('q repor') : ci('repor'),
    horaRepor: ci('hora repor'),
    qOp:       ci('q. op') >= 0 ? ci('q. op') : ci('q.op') >= 0 ? ci('q.op') : ci('op'),
    horaLlegada: ci('llegada'),
    recep:     ci('recep'),
    notas:     ci('nota') >= 0 ? ci('nota') : ci('info'),
    tarifa:    ci('tarifa'),
    flota:     ci('flota'),
  };

  RAW_ROWS = values.slice(hIdx + 1)
    .filter(r => r.some(c => c !== null && c !== '' && c !== undefined))
    .map(r => {
      const g = idx => (idx >= 0 && idx < r.length) ? r[idx] : '';
      const fecha    = parseDate(g(H.fecha));
      const hrCorte  = parseTime(g(H.hrCorte));
      const horaRepor  = parseTime(g(H.horaRepor));
      const horaLlegada = parseTime(g(H.horaLlegada));
      const qRepor   = parseNum(g(H.qRepor));
      const qOp      = parseNum(g(H.qOp));
      const tarifa   = parseMoney(g(H.tarifa));

      // Computed
      const CORTE_15   = 15 * 60;  // 15:00 en minutos
      const CORTE_1515 = 15 * 60 + 15; // 15:15 en minutos
      const transitoMin     = (horaRepor !== null && horaLlegada !== null) ? horaLlegada - horaRepor : null;
      // tardanzaMin: minutos de llegada respecto a las 15:00 (positivo = tarde, negativo = a tiempo)
      const tardanzaMin     = horaLlegada !== null ? horaLlegada - CORTE_15 : null;
      const llegadaTardio   = horaLlegada !== null && horaLlegada > CORTE_15;   // llegó post 15:00
      const llegadaCritica  = horaLlegada !== null && horaLlegada > CORTE_1515; // llegó post 15:15

      return {
        fecha, hrCorte, cliente: str(g(H.cliente)), comuna: normalizarComuna(str(g(H.comuna))),
        conductor: str(g(H.conductor)), qRepor, horaRepor, qOp, horaLlegada,
        recep: str(g(H.recep)), notas: str(g(H.notas)), tarifa, flota: str(g(H.flota)),
        transitoMin, tardanzaMin, llegadaTardio, llegadaCritica,
      };
    })
    .filter(r => r.cliente || r.conductor || r.qRepor > 0);

  // Guardar filas de consolidación diaria (conductor "Y") — son la suma autorizada
  window.TOTAL_ROWS = RAW_ROWS.filter(r => {
    const cond = r.conductor.trim().toUpperCase();
    const flot = r.flota.trim().toUpperCase();
    return cond === 'Y' || flot === 'TOTAL';
  });
  // DEBUG — abrir F12 > Consola para ver estos valores
  console.log('[RETIROS DEBUG] TOTAL_ROWS count:', window.TOTAL_ROWS.length);
  console.log('[RETIROS DEBUG] TOTAL_ROWS qRepor sum:', window.TOTAL_ROWS.reduce((s,r)=>s+r.qRepor,0));
  console.log('[RETIROS DEBUG] Muestra TOTAL_ROWS[0]:', window.TOTAL_ROWS[0]);
  // muestra las primeras 3 filas "Y" tal como llegan del API
  const _sampleY = RAW_ROWS.filter(r => r.conductor && r.conductor.trim().toUpperCase()==='Y').slice(0,3);
  console.log('[RETIROS DEBUG] Muestra filas conductor===Y antes de excluir:', _sampleY);
  console.log('[RETIROS DEBUG] RAW_ROWS total antes de excluir Y:', RAW_ROWS.length);
  // Excluir filas de consolidación del análisis operacional
  RAW_ROWS = RAW_ROWS.filter(r => {
    const cond = r.conductor.trim().toUpperCase();
    const flot = r.flota.trim().toUpperCase();
    return cond !== 'Y' && cond !== 'TOTAL' && flot !== 'TOTAL';
  });

  // Separar filas sin viaje real (NON_TRIP) del análisis principal.
  // Estas filas no representan un chofer que fue a retirar — se excluyen de
  // conteos, promedios, tardíos y viajes en vacío cobrables.
  window.AVISAN_ROWS = RAW_ROWS.filter(r => isNonTrip(r.conductor));
  RAW_ROWS           = RAW_ROWS.filter(r => !isNonTrip(r.conductor));

  // Detectar mes predominante del archivo para filtrar meses anteriores
  const fechasValidas = RAW_ROWS.map(r => r.fecha).filter(Boolean);
  if (fechasValidas.length) {
    fechasValidas.sort((a,b) => b - a); // más recientes primero
    const mesRef = fechasValidas[0]; // mes de la fila más reciente
    // Usar el mes modal (más frecuente) para evitar que una sola fila con fecha futura
    // rompa el filtro y deje sin datos el análisis (era el bug de los 14k paquetes)
    const monthFreq = {};
    fechasValidas.forEach(d => {
      const k = d.getFullYear() + '-' + d.getMonth();
      monthFreq[k] = (monthFreq[k]||0) + 1;
    });
    const [mesKey] = Object.entries(monthFreq).sort((a,b) => b[1]-a[1])[0];
    const [anioActual, mesActual] = mesKey.split('-').map(Number);
    // Filtrar solo el mes más reciente del archivo
    RAW_ROWS = RAW_ROWS.filter(r => {
      if (!r.fecha) return true; // sin fecha pasa
      return r.fecha.getMonth() === mesActual && r.fecha.getFullYear() === anioActual;
    });
    // Aplicar el mismo filtro de mes a AVISAN_ROWS y TOTAL_ROWS
    window.AVISAN_ROWS = window.AVISAN_ROWS.filter(r => {
      if (!r.fecha) return true;
      return r.fecha.getMonth() === mesActual && r.fecha.getFullYear() === anioActual;
    });
    window.TOTAL_ROWS = window.TOTAL_ROWS.filter(r => {
      if (!r.fecha) return true;
      return r.fecha.getMonth() === mesActual && r.fecha.getFullYear() === anioActual;
    });
  }

  ROWS = [...RAW_ROWS];
  populateFilters();
}

// ─── HELPERS ─────────────────────────────────────────────────────────────────
function parseTime(val) {
  if (val === null || val === undefined || val === '') return null;
  if (typeof val === 'number' && val > 0 && val < 2) return Math.round(val * 1440);
  const s = val.toString().trim();
  const m = s.match(/(\d{1,2}):(\d{2})/);
  return m ? parseInt(m[1])*60 + parseInt(m[2]) : null;
}
function parseDate(val) {
  if (!val) return null;
  if (typeof val === 'number') { const d=new Date((val-25569)*86400000); return isNaN(d)?null:d; }
  const s = val.toString().trim();
  const m1 = s.match(/^(\d{1,2})[\/-](\d{1,2})[\/-](\d{4})/);
  if (m1) return new Date(+m1[3],+m1[2]-1,+m1[1]);
  const d = new Date(s); return isNaN(d) ? null : d;
}
function parseNum(val) {
  if (typeof val === 'number') return val;
  const n = parseFloat(str(val).replace(/[^\d.-]/g,''));
  return isNaN(n) ? 0 : n;
}
function parseMoney(val) {
  if (typeof val === 'number') return val;
  const n = parseFloat(str(val).replace(/[$\s.]/g,'').replace(',','.'));
  return isNaN(n) ? 0 : n;
}
function str(v) { return v !== null && v !== undefined ? v.toString().trim() : ''; }
function fmtTime(min) {
  if (min === null) return '—';
  const h = Math.floor(Math.abs(min)/60), m = Math.abs(min)%60;
  const sign = min < 0 ? '-' : '';
  return `${sign}${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
}
function fmtMin(min) {
  if (min === null) return '—';
  const h = Math.floor(Math.abs(min)/60), m = Math.abs(min)%60;
  if (h === 0) return `${m}min`;
  return `${h}h ${m}min`;
}
function fmtDate(d) {
  if (!d) return '—';
  return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`;
}
function fmtMoney(n) { return '$' + Math.round(n).toLocaleString('es-CL'); }
function avg(arr) { return arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0; }
function groupBy(arr, fn) {
  return arr.reduce((m,x) => { const k=fn(x); (m[k]=m[k]||[]).push(x); return m; }, {});
}

// ─── FILTERS ─────────────────────────────────────────────────────────────────
// Multi-select flota helpers
function getSelectedFlotas() {
  return [...document.querySelectorAll('#flota-dd input[type=checkbox]:not(#flota-all):checked')]
    .map(c => c.value);
}
function updateFlotaBtn() {
  const sel = getSelectedFlotas();
  const lbl = document.getElementById('flota-label');
  if (!lbl) return;
  if (sel.length === 0) lbl.textContent = '— Todas las flotas';
  else if (sel.length === 1) lbl.textContent = sel[0];
  else lbl.textContent = sel[0] + '  +' + (sel.length - 1) + ' más';
}
function syncFlotaAll() {
  const cbs = [...document.querySelectorAll('#flota-dd input[type=checkbox]:not(#flota-all)')];
  const allCb = document.getElementById('flota-all');
  if (!allCb) return;
  allCb.checked  = cbs.every(c => c.checked);
  allCb.indeterminate = !allCb.checked && cbs.some(c => c.checked);
}
function onFlotaAllChange(cb) {
  document.querySelectorAll('#flota-dd input[type=checkbox]:not(#flota-all)').forEach(c => c.checked = cb.checked);
  updateFlotaBtn(); applyFilters();
}
function toggleFlotaDD(e) {
  e.stopPropagation();
  document.getElementById('flota-dd').classList.toggle('open');
}
document.addEventListener('click', e => {
  const w = document.getElementById('flota-wrap');
  if (w && !w.contains(e.target)) document.getElementById('flota-dd')?.classList.remove('open');
});
// Expose to global scope (script is type="module")
window.toggleFlotaDD   = toggleFlotaDD;
window.onFlotaAllChange = onFlotaAllChange;

function populateFilters() {
  const populate = (id, vals) => {
    const sel = document.getElementById(id);
    const cur = sel.value;
    sel.innerHTML = `<option value="">— ${sel.options[0]?.text.replace('—','').trim()||''}</option>`;
    [...new Set(vals)].filter(Boolean).sort().forEach(v => {
      const o=document.createElement('option'); o.value=v; o.textContent=v;
      if(v===cur) o.selected=true;
      sel.appendChild(o);
    });
  };
  populate('f-cliente',   RAW_ROWS.map(r=>r.cliente));
  populate('f-conductor', RAW_ROWS.map(r=>r.conductor));
  // Multi-select flota
  const flotaVals = [...new Set(RAW_ROWS.map(r=>r.flota))].filter(Boolean).sort();
  const dd = document.getElementById('flota-dd');
  const prevSel = getSelectedFlotas();
  // Remove all except the "all" label
  [...dd.querySelectorAll('label:not(.ms-all)')].forEach(l=>l.remove());
  flotaVals.forEach(v => {
    const lbl = document.createElement('label');
    const cb  = document.createElement('input');
    cb.type = 'checkbox'; cb.value = v;
    if (prevSel.includes(v)) cb.checked = true;
    cb.onchange = () => { syncFlotaAll(); updateFlotaBtn(); applyFilters(); };
    lbl.appendChild(cb);
    lbl.appendChild(document.createTextNode(' ' + v));
    dd.appendChild(lbl);
  });
  syncFlotaAll();
  updateFlotaBtn();
  populate('f-comuna',    RAW_ROWS.map(r=>r.comuna));
}

window.applyFilters = () => {
  const cli  = document.getElementById('f-cliente').value;
  const cond = document.getElementById('f-conductor').value;
  const flotas = getSelectedFlotas(); // array — empty = todas
  const com  = document.getElementById('f-comuna').value;
  const srch = (document.getElementById('f-search')||{value:''}).value.toLowerCase();
  ROWS = RAW_ROWS.filter(r =>
    (!cli  || r.cliente===cli) &&
    (!cond || r.conductor===cond) &&
    (!flotas.length || flotas.includes(r.flota)) &&
    (!com  || r.comuna===com) &&
    (!srch || [r.cliente,r.conductor,r.notas,r.recep].join(' ').toLowerCase().includes(srch))
  );
  document.getElementById('filter-count').textContent = `${ROWS.length} de ${RAW_ROWS.length} registros`;
  renderAll();
};

window.clearFilters = () => {
  ['f-cliente','f-conductor','f-comuna'].forEach(id => document.getElementById(id).value='');
  document.querySelectorAll('#flota-dd input[type=checkbox]').forEach(c=>c.checked=false);
  updateFlotaBtn();
  const s = document.getElementById('f-search'); if(s) s.value='';
  ROWS = [...RAW_ROWS];
  document.getElementById('filter-count').textContent='';
  renderAll();
};

// ─── CHARTS ──────────────────────────────────────────────────────────────────
const _charts = {};
function mkChart(id, type, labels, datasets, opts={}) {
  if (_charts[id]) _charts[id].destroy();
  const ctx = document.getElementById(id);
  if (!ctx) return;
  _charts[id] = new Chart(ctx, {
    type, data:{labels,datasets},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:opts.legend||false},tooltip:{callbacks:{label: ctx=>`${ctx.parsed.y??ctx.parsed.x??ctx.raw}`}}},
      scales: type==='bar'||type==='line' ? {
        x:{grid:{display:false},...(opts.x||{})},
        y:{grid:{color:'#f0f0f0'},beginAtZero:true,...(opts.y||{})}
      } : {},
      indexAxis: opts.horizontal ? 'y' : 'x',
      ...opts.extra
    }
  });
}

// ─── RENDER ALL ──────────────────────────────────────────────────────────────
// ─── VIAJES EN VACÍO — detección ─────────────────────────────────────────────
function getViajesVacio() {
  // ROWS ya excluye NON_TRIP desde parseData — si llegó acá, el chofer fue.
  // Cobrable: conductor identificado + tarifa > $0 + 0 paquetes.
  return ROWS.filter(r =>
    (r.qOp === 0 || r.qRepor === 0) &&
    r.conductor && r.conductor.trim() !== '' &&
    r.tarifa > 0
  );
}

function renderAll() {
  renderDashboard();
  renderChofer();
  renderComunas();
  renderClientes();
  renderTiempos();
  renderDetalle();
}

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
function renderDashboard() {
  const totalRetiros   = ROWS.length;
  const vDash = getViajesVacio();
  const totalPaqOps    = ROWS.reduce((s,r)=>s+r.qRepor,0);  // para concordancia (solo retiros reales)
  // Usar filas TOTAL (conductor "Y") como fuente del KPI si el archivo las tiene
  // → esas son la suma que el equipo ops registra día a día y coincide con lo que se cuenta manualmente
  console.log('[RETIROS DEBUG] renderDashboard → TOTAL_ROWS.length:', window.TOTAL_ROWS ? window.TOTAL_ROWS.length : 'undefined');
  console.log('[RETIROS DEBUG] renderDashboard → totalPaqOps (fallback):', totalPaqOps);
  const totalPaq       = window.TOTAL_ROWS && window.TOTAL_ROWS.length > 0
                         ? window.TOTAL_ROWS.reduce((s,r)=>s+r.qRepor,0)
                         : totalPaqOps; // fallback si el archivo no tiene filas TOTAL
  console.log('[RETIROS DEBUG] renderDashboard → totalPaq (final):', totalPaq);
  const totalQOp       = ROWS.reduce((s,r)=>s+r.qOp,0);
  const concordancia   = totalPaqOps > 0 ? Math.round(totalQOp/totalPaqOps*100) : 0;
  const discordantes   = ROWS.filter(r => r.qRepor > 0 && r.qOp !== r.qRepor);
  const totalTarifa    = ROWS.reduce((s,r)=>s+r.tarifa,0);
  const tiemposT       = ROWS.map(r=>r.transitoMin).filter(t=>t!==null&&t>0&&t<480);
  const avgTransito    = tiemposT.length ? Math.round(avg(tiemposT)) : null;

  document.getElementById('kpis').innerHTML = `
    <div class="kpi blue"><div class="kpi-label">Total Retiros</div><div class="kpi-val">${totalRetiros}</div></div>
    <div class="kpi green"><div class="kpi-label">Total Paquetes</div><div class="kpi-val">${totalPaq.toLocaleString()}</div><div class="kpi-sub">Q Reportados</div></div>
    <div class="kpi ${concordancia>=95?'green':'orange'}" onclick="verDiscordancias()" title="Ver registros sin concordancia" style="cursor:pointer"><div class="kpi-label">Concordancia</div><div class="kpi-val">${concordancia}%</div><div class="kpi-sub">Q.op / Q.Repor. · ${discordantes.length} registros ↗</div></div>
    <div class="kpi purple"><div class="kpi-label">Total Tarifa</div><div class="kpi-val">${fmtMoney(totalTarifa)}</div></div>
    <div class="kpi ${avgTransito!==null&&avgTransito<=90?'green':'orange'}"><div class="kpi-label">Tránsito Prom.</div><div class="kpi-val">${avgTransito!==null?fmtMin(avgTransito):'—'}</div><div class="kpi-sub">Retiro → Bodega</div></div>
    <div class="kpi ${vDash.length>0?'red':'green'}"><div class="kpi-label">Viajes Vacíos</div><div class="kpi-val">${vDash.length}</div><div class="kpi-sub" style="cursor:pointer" onclick="showTab('cobros');renderCobros()">Ver cobros →</div></div>
  `;

  // Chart: retiros por día
  const byDay = groupBy(ROWS.filter(r=>r.fecha), r=>`${r.fecha.getDate().toString().padStart(2,'0')}/${(r.fecha.getMonth()+1).toString().padStart(2,'0')}`);
  const dayLabels = Object.keys(byDay).sort();
  document.getElementById('charts-row1').innerHTML = `
    <div class="chart-card"><div class="chart-title">Retiros por día</div><div class="chart-wrap"><canvas id="ch-by-day"></canvas></div></div>
    <div class="chart-card"><div class="chart-title">Top 10 clientes por paquetes retirados</div><div class="chart-wrap"><canvas id="ch-top-cli"></canvas></div></div>
  `;
  mkChart('ch-by-day','bar', dayLabels, [{data:dayLabels.map(d=>byDay[d].length),backgroundColor:'#1a73e8',borderRadius:4}]);

  const byClient = groupBy(ROWS, r=>r.cliente);
  const topCli = Object.entries(byClient).map(([k,v])=>({k,v:v.reduce((s,r)=>s+r.qRepor,0)})).sort((a,b)=>b.v-a.v).slice(0,10);
  document.getElementById('charts-row2').innerHTML = `
    <div class="chart-card"><div class="chart-title">Paquetes por cliente (Top 10)</div><div class="chart-wrap"><canvas id="ch-cli-paq"></canvas></div></div>
    <div class="chart-card"><div class="chart-title">Distribución por tipo de flota</div><div class="chart-wrap"><canvas id="ch-flota"></canvas></div></div>
  `;
  mkChart('ch-top-cli','bar', topCli.map(x=>x.k), [{data:topCli.map(x=>x.v),backgroundColor:'#34a853',borderRadius:4}], {horizontal:false,x:{ticks:{maxRotation:30,font:{size:10}}}});
  mkChart('ch-cli-paq','bar', topCli.map(x=>x.k), [{data:topCli.map(x=>x.v),backgroundColor:'#1a73e8',borderRadius:4}], {horizontal:true,x:{},y:{ticks:{font:{size:10}}}});

  const byFlota = groupBy(ROWS, r=>r.flota||'Sin dato');
  const flotaKeys = Object.keys(byFlota);
  mkChart('ch-flota','doughnut', flotaKeys, [{data:flotaKeys.map(k=>byFlota[k].length),backgroundColor:['#1a73e8','#34a853','#fb8c00','#9334e8','#e53935','#00acc1']}],{legend:true,extra:{cutout:'60%'}});
}

// ─── POR CHOFER ──────────────────────────────────────────────────────────────
function renderChofer() {
  const byC = groupBy(ROWS.filter(r=>r.conductor), r=>r.conductor);
  const data = Object.entries(byC).map(([cond,rows])=>{
    const tiempos = rows.map(r=>r.transitoMin).filter(t=>t!==null&&t>0&&t<480);
    const post15   = rows.filter(r=>r.llegadaTardio).length;
    const post1515 = rows.filter(r=>r.llegadaCritica).length;
    return {
      cond, retiros:rows.length,
      paquetes:rows.reduce((s,r)=>s+r.qRepor,0),
      tarifa:rows.reduce((s,r)=>s+r.tarifa,0),
      avgTransito:tiempos.length?Math.round(avg(tiempos)):null,
      post15, post1515, flota:[...new Set(rows.map(r=>r.flota))].filter(Boolean).join(', ')
    };
  }).sort((a,b)=>b.paquetes-a.paquetes);

  // Chart tiempos
  const con_t = data.filter(d=>d.avgTransito!==null).sort((a,b)=>b.avgTransito-a.avgTransito);
  mkChart('ch-chofer-tiempo','bar',
    con_t.map(d=>d.cond),
    [{data:con_t.map(d=>d.avgTransito),backgroundColor:con_t.map(d=>d.avgTransito>90?'#e53935':d.avgTransito>60?'#fb8c00':'#34a853'),borderRadius:4,label:'Min'}],
    {horizontal:false,x:{ticks:{maxRotation:30,font:{size:10}}},y:{title:{display:true,text:'Minutos'}}}
  );

  // Table
  document.getElementById('tbl-chofer').innerHTML = `
    <thead><tr><th>Conductor</th><th>Retiros</th><th>Paquetes</th><th>Tránsito Prom.</th><th title='Llegaron al CD después de las 15:00'>Post 15:00 ⚠️</th><th title='Llegaron al CD después de las 15:15 — crítico'>Post 15:15 🔴</th><th>Tarifa Total</th><th>Flota</th></tr></thead>
    <tbody>${data.map(d=>`<tr>
      <td><strong>${d.cond}</strong></td>
      <td>${d.retiros}</td>
      <td>${d.paquetes.toLocaleString()}</td>
      <td><span class="badge ${d.avgTransito===null?'b-info':d.avgTransito<=60?'b-ok':d.avgTransito<=90?'b-warn':'b-red'}">${d.avgTransito!==null?fmtMin(d.avgTransito):'—'}</span></td>
      <td style="text-align:center">${d.post15>0?`<span class="badge b-warn">${d.post15}</span>`:'<span class="badge b-ok">0</span>'}</td>
      <td style="text-align:center">${d.post1515>0?`<span class="badge b-red">${d.post1515}</span>`:'<span class="badge b-ok">0</span>'}</td>
      <td>${fmtMoney(d.tarifa)}</td>
      <td><small>${d.flota}</small></td>
    </tr>`).join('')}</tbody>
  `;
}

// ─── COMUNAS ─────────────────────────────────────────────────────────────────

// ─── CLIENTES ─────────────────────────────────────────────────────────────────
let _cliSort = { key: 'paquetes', dir: 'desc' };

function buildClienteStats() {
  const map = {};
  for (const r of ROWS) {
    const k = r.cliente || '(sin cliente)';
    if (!map[k]) map[k] = { nombre:k, retiros:0, paquetes:0, tarifa:0, transitoSum:0, transitoCnt:0, tardios:0 };
    map[k].retiros++;
    map[k].paquetes  += (r.qOp || 0);
    map[k].tarifa    += (r.tarifa || 0);
    if (r.transitoMin != null && r.transitoMin > 0 && r.transitoMin < 600) {
      map[k].transitoSum += r.transitoMin;
      map[k].transitoCnt++;
    }
    if (r.llegadaTardio) map[k].tardios++; // post 15:00
  }
  return Object.values(map).map(c => ({
    ...c,
    paq_por_retiro: c.retiros ? Math.round(c.paquetes / c.retiros) : 0,
    costo_retiro:   c.retiros ? Math.round(c.tarifa / c.retiros)   : 0,
    transito:       c.transitoCnt ? Math.round(c.transitoSum / c.transitoCnt) : null,
    tardios_pct:    c.retiros ? Math.round(c.tardios / c.retiros * 1000) / 10 : 0,
  }));
}

window.sortClientes = function(key, dir) {
  _cliSort = { key, dir };
  renderClientes();
};

function renderClientes() {
  const stats = buildClienteStats();
  const total = stats.length;

  // KPI cards
  const kpiEl = document.getElementById('cli-kpis');
  if (kpiEl) {
    const totalPaq  = stats.reduce((s,c)=>s+c.paquetes,0);
    const totalTar  = stats.reduce((s,c)=>s+c.tarifa,0);
    const menorPaq  = [...stats].sort((a,b)=>a.paquetes-b.paquetes)[0];
    const mayorCost = [...stats].sort((a,b)=>b.costo_retiro-a.costo_retiro)[0];
    kpiEl.innerHTML = [
      { label:'Clientes únicos',   val: total },
      { label:'Total paquetes',    val: totalPaq.toLocaleString('es-CL') },
      { label:'Tarifa total',      val: '$'+Math.round(totalTar).toLocaleString('es-CL') },
      { label:'Menor paquetería',  val: menorPaq ? menorPaq.nombre.substring(0,20) : '—', sub: menorPaq ? menorPaq.paquetes+' paq.' : '' },
      { label:'Mayor costo/retiro',val: mayorCost ? mayorCost.nombre.substring(0,20) : '—', sub: mayorCost ? '$'+mayorCost.costo_retiro.toLocaleString('es-CL') : '' },
    ].map(k=>`<div style="background:#f8faff;border:1px solid #dbe9ff;border-radius:8px;padding:10px 12px">
      <div style="font-size:15px;font-weight:700;color:#1a1a2e">${k.val}</div>
      ${k.sub ? `<div style="font-size:11px;color:#6b7280">${k.sub}</div>` : ''}
      <div style="font-size:11px;color:#9ca3af;margin-top:2px">${k.label}</div>
    </div>`).join('');
  }

  // Sort
  const { key, dir } = _cliSort;
  stats.sort((a,b) => {
    const va = a[key] ?? (dir==='asc'?Infinity:-Infinity);
    const vb = b[key] ?? (dir==='asc'?Infinity:-Infinity);
    return dir === 'asc' ? va - vb : vb - va;
  });

  // Percentiles para colores (costo_retiro y paquetes)
  const costos = stats.map(c=>c.costo_retiro).filter(Boolean).sort((a,b)=>a-b);
  const paqArr = stats.map(c=>c.paquetes).sort((a,b)=>a-b);
  const p25costo = costos[Math.floor(costos.length*0.25)] || 0;
  const p75costo = costos[Math.floor(costos.length*0.75)] || 0;
  const p25paq   = paqArr[Math.floor(paqArr.length*0.25)] || 0;

  function costoColor(v) {
    if (v >= p75costo) return '#fef2f2'; // rojo claro — caro
    if (v <= p25costo) return '#f0fdf4'; // verde claro — barato
    return '';
  }
  function paqColor(v) {
    if (v <= p25paq) return '#fef9c3'; // amarillo — poca paquetería
    return '';
  }

  const tbody = document.getElementById('tbody-clientes');
  if (!tbody) return;
  tbody.innerHTML = stats.map(c => {
    const rowBg = c.costo_retiro >= p75costo && c.paquetes <= p25paq ? '#fff1f2' : ''; // rojo si ambos malos
    const tardBadge = c.tardios > 0
      ? `<span style="background:#fef3c7;color:#b45309;padding:2px 6px;border-radius:10px;font-size:11px;font-weight:600">${c.tardios} (${c.tardios_pct}%)</span>`
      : `<span style="color:#16a34a;font-size:12px">0</span>`;
    const transitoStr = c.transito !== null ? `${c.transito}min` : '—';
    return `<tr style="background:${rowBg}">
      <td style="font-weight:500;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${c.nombre}">${c.nombre}</td>
      <td style="text-align:center">${c.retiros}</td>
      <td style="text-align:center;background:${paqColor(c.paquetes)}">${c.paquetes.toLocaleString('es-CL')}</td>
      <td style="text-align:center">${c.paq_por_retiro}</td>
      <td style="text-align:right">$${Math.round(c.tarifa).toLocaleString('es-CL')}</td>
      <td style="text-align:right;background:${costoColor(c.costo_retiro)};font-weight:600">$${c.costo_retiro.toLocaleString('es-CL')}</td>
      <td style="text-align:center">${transitoStr}</td>
      <td style="text-align:center">${tardBadge}</td>
    </tr>`;
  }).join('');
}

function renderComunas() {
  const byC = groupBy(ROWS.filter(r=>r.comuna), r=>r.comuna);
  const data = Object.entries(byC).map(([com,rows])=>{
    const tiempos = rows.map(r=>r.transitoMin).filter(t=>t!==null&&t>0&&t<480);
    return { com, retiros:rows.length, paquetes:rows.reduce((s,r)=>s+r.qRepor,0), avgTransito:tiempos.length?Math.round(avg(tiempos)):null };
  }).sort((a,b)=>b.paquetes-a.paquetes);

  const topCom = data.slice(0,15);
  mkChart('ch-comuni-paq','bar', topCom.map(d=>d.com), [{data:topCom.map(d=>d.paquetes),backgroundColor:'#1a73e8',borderRadius:4}],
    {horizontal:true,y:{ticks:{font:{size:10}}}});

  const conT = data.filter(d=>d.avgTransito!==null).sort((a,b)=>b.avgTransito-a.avgTransito).slice(0,15);
  mkChart('ch-comuni-tiempo','bar', conT.map(d=>d.com), [{data:conT.map(d=>d.avgTransito),backgroundColor:conT.map(d=>d.avgTransito>90?'#e53935':d.avgTransito>60?'#fb8c00':'#34a853'),borderRadius:4}],
    {horizontal:true,y:{ticks:{font:{size:10}}}});

  document.getElementById('tbl-comunas').innerHTML = `
    <thead><tr><th>Comuna</th><th>Retiros</th><th>Paquetes</th><th>Tránsito Prom.</th></tr></thead>
    <tbody>${data.map(d=>`<tr>
      <td><strong>${d.com}</strong></td><td>${d.retiros}</td><td>${d.paquetes.toLocaleString()}</td>
      <td><span class="badge ${d.avgTransito===null?'b-info':d.avgTransito<=60?'b-ok':d.avgTransito<=90?'b-warn':'b-red'}">${d.avgTransito!==null?fmtMin(d.avgTransito):'—'}</span></td>
    </tr>`).join('')}</tbody>
  `;
}

// ─── TIEMPOS ─────────────────────────────────────────────────────────────────
function renderTiempos() {
  const tiempos = ROWS.map(r=>r.transitoMin).filter(t=>t!==null&&t>0&&t<480);
  const tardios  = ROWS.filter(r=>r.llegadaTardio);   // llegada post 15:00
  const criticos = ROWS.filter(r=>r.llegadaCritica); // llegada post 15:15
  const avgT    = tiempos.length ? Math.round(avg(tiempos)) : null;
  const maxT    = tiempos.length ? Math.max(...tiempos) : null;
  const minT    = tiempos.length ? Math.min(...tiempos) : null;

  document.getElementById('kpis-tiempos').innerHTML = `
    <div class="kpi blue"><div class="kpi-label">Tránsito Promedio</div><div class="kpi-val">${avgT!==null?fmtMin(avgT):'—'}</div></div>
    <div class="kpi green"><div class="kpi-label">Más rápido</div><div class="kpi-val">${minT!==null?fmtMin(minT):'—'}</div></div>
    <div class="kpi red"><div class="kpi-label">Más lento</div><div class="kpi-val">${maxT!==null?fmtMin(maxT):'—'}</div></div>
    <div class="kpi orange"><div class="kpi-label">Post 15:00</div><div class="kpi-val">${tardios.length}</div><div class="kpi-sub">${criticos.length} post 15:15 🔴</div></div>
  `;

  // Distribución histograma
  const buckets = [[0,30],[30,60],[60,90],[90,120],[120,180],[180,999]];
  const labels  = ['<30 min','30-60 min','60-90 min','90-120 min','2-3 hrs','>3 hrs'];
  const counts  = buckets.map(([lo,hi])=>tiempos.filter(t=>t>=lo&&t<hi).length);
  mkChart('ch-dist-transito','bar', labels, [{data:counts,backgroundColor:'#1a73e8',borderRadius:4}]);

  // Tardíos por conductor
  const byC = groupBy(tardios.filter(r=>r.conductor), r=>r.conductor);
  const tardKeys = Object.keys(byC).sort((a,b)=>byC[b].length-byC[a].length).slice(0,12);
  mkChart('ch-tardios','bar', tardKeys, [{data:tardKeys.map(k=>byC[k].length),backgroundColor:'#e53935',borderRadius:4}],
    {x:{ticks:{maxRotation:30,font:{size:10}}}});

  // Tabla tardíos
  const tardSorted = [...tardios].sort((a,b)=>(b.tardanzaMin||0)-(a.tardanzaMin||0)); // tardanzaMin = llegada - 15:00
  document.getElementById('tbl-tardios').innerHTML = `
    <thead><tr><th>Fecha</th><th>Cliente</th><th>Conductor</th><th>HR Corte</th><th>Hora Repor.</th><th>Demora</th><th>Tránsito</th></tr></thead>
    <tbody>${tardSorted.slice(0,50).map(r=>`<tr>
      <td>${fmtDate(r.fecha)}</td>
      <td>${r.cliente}</td>
      <td>${r.conductor}</td>
      <td><strong>${fmtTime(r.horaLlegada)}</strong></td>
      <td><span class="badge ${r.llegadaCritica?'b-red':'b-warn'}">+${fmtMin(r.tardanzaMin)} min</span></td>
      <td>${fmtTime(r.horaRepor)}</td>
      <td>${r.transitoMin!==null?fmtMin(r.transitoMin):'—'}</td>
    </tr>`).join('')}</tbody>
  `;
}

// ─── DETALLE ─────────────────────────────────────────────────────────────────
function renderDetalle() {
  document.getElementById('det-count').textContent = `${ROWS.length} registros`;
  document.getElementById('det-tbody').innerHTML = ROWS.map(r=>{
    const esVacio = (r.qOp === 0 || r.qRepor === 0);
    const trStyle = esVacio ? ' style="background:#fff7ed"' : '';
    const clave   = `${fmtDate(r.fecha)}_${r.cliente}_${r.conductor}`;
    return `<tr${trStyle}>
    <td>${fmtDate(r.fecha)}</td>
    <td>${r.cliente}</td>
    <td>${r.comuna}</td>
    <td>${r.conductor}</td>
    <td style="text-align:right">${r.qRepor||0}</td>
    <td>${fmtTime(r.horaRepor)}</td>
    <td style="text-align:right">${r.qOp||0}</td>
    <td>${fmtTime(r.horaLlegada)}</td>
    <td><span class="badge ${r.transitoMin===null?'b-info':r.transitoMin<=60?'b-ok':r.transitoMin<=90?'b-warn':'b-red'}">${r.transitoMin!==null?fmtMin(r.transitoMin):'—'}</span></td>
    <td>${r.tarifa?fmtMoney(r.tarifa):'—'}</td>
    <td>${r.flota||'—'}</td>
    <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${r.notas}">${r.notas||''}</td>
    <td>${esVacio
      ? `<button onclick="showTab('cobros');renderCobros()"
            style="background:#fef3c7;color:#b45309;border:1px solid #f59e0b;border-radius:8px;padding:3px 8px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap">
            🚫 Vacío 💰
          </button>`
      : ''}</td>
  </tr>`;
  }).join('');
}

// ─── EXPORT CSV ──────────────────────────────────────────────────────────────
window.exportCSV = () => {
  const headers = ['Fecha','Cliente','Comuna','Conductor','Q Repor','Hora Repor','Q op','Hora Llegada','Transito (min)','Tarifa','Flota','Notas'];
  const rows = ROWS.map(r=>[
    fmtDate(r.fecha), r.cliente, r.comuna, r.conductor, r.qRepor, fmtTime(r.horaRepor),
    r.qOp, fmtTime(r.horaLlegada), r.transitoMin??'', r.tarifa, r.flota, r.notas
  ]);
  const csv = [headers, ...rows].map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob(['﻿'+csv],{type:'text/csv;charset=utf-8'}));
  a.download = 'retiros_export.csv'; a.click();
};

// ─── UI HELPERS ──────────────────────────────────────────────────────────────
function showSection(name) {
  ['mslogin','load','loading','data'].forEach(s => {
    const el = document.getElementById('sec-'+s);
    if (el) { el.classList.toggle('visible', s===name); }
  });
}
function setLoadingMsg(msg) { document.getElementById('loading-msg').textContent = msg; }

// ─── COBROS ───────────────────────────────────────────────────────────────────
// Mapa global para evitar JSON en atributos onclick (evita quiebre de comillas)
window._COBRO_MAP = {};

window.verDiscordancias = () => {
  const rows = ROWS.filter(r => r.qRepor > 0 && r.qOp !== r.qRepor)
    .sort((a,b) => Math.abs(b.qRepor-b.qOp) - Math.abs(a.qRepor-a.qOp));

  // Crear o reusar modal
  let modal = document.getElementById('modal-discordancias');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'modal-discordancias';
    modal.style.cssText = 'position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;padding:20px';
    modal.onclick = e => { if(e.target===modal) modal.style.display='none'; };
    document.body.appendChild(modal);
  }

  const totalDiff = rows.reduce((s,r) => s + Math.abs(r.qRepor - r.qOp), 0);

  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;width:100%;max-width:900px;max-height:80vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3)">
      <div style="padding:16px 20px;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <div>
          <h3 style="font-size:16px;font-weight:700;color:#111">⚠️ Registros sin concordancia</h3>
          <p style="font-size:12px;color:#6b7280;margin-top:2px">${rows.length} registros · Diferencia total: ${totalDiff.toLocaleString('es-CL')} paquetes</p>
        </div>
        <button onclick="document.getElementById('modal-discordancias').style.display='none'"
          style="background:#f3f4f6;border:none;border-radius:6px;padding:6px 12px;cursor:pointer;font-size:13px;color:#374151">✕ Cerrar</button>
      </div>
      <div style="overflow-y:auto;flex:1">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead style="position:sticky;top:0;background:#f9fafb">
            <tr>
              <th style="padding:10px 14px;text-align:left;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Fecha</th>
              <th style="padding:10px 14px;text-align:left;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Cliente</th>
              <th style="padding:10px 14px;text-align:left;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Conductor</th>
              <th style="padding:10px 14px;text-align:right;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Q.Repor</th>
              <th style="padding:10px 14px;text-align:right;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Q.Op</th>
              <th style="padding:10px 14px;text-align:right;color:#6b7280;font-weight:600;border-bottom:1px solid #e5e7eb">Diferencia</th>
            </tr>
          </thead>
          <tbody>
            ${rows.map((r,i) => {
              const diff = r.qOp - r.qRepor;
              const color = diff < 0 ? '#dc2626' : '#16a34a';
              const bg    = i%2 ? '#f9fafb' : '#fff';
              return '<tr style="background:' + bg + '">' +
                '<td style="padding:9px 14px;color:#374151">' + fmtDate(r.fecha) + '</td>' +
                '<td style="padding:9px 14px;font-weight:600;color:#111">' + r.cliente + '</td>' +
                '<td style="padding:9px 14px;color:#6b7280">' + (r.conductor||'—') + '</td>' +
                '<td style="padding:9px 14px;text-align:right">' + r.qRepor + '</td>' +
                '<td style="padding:9px 14px;text-align:right">' + r.qOp + '</td>' +
                '<td style="padding:9px 14px;text-align:right;font-weight:700;color:' + color + '">' + (diff>0?'+':'') + diff + '</td>' +
                '</tr>';
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
  modal.style.display = 'flex';
};

window.renderCobros = async () => {
  const cont = document.getElementById('cobros-container');
  if (!cont) return;

  cont.innerHTML = '<p style="color:#888;font-size:13px;padding:12px">Cargando...</p>';

  const vacios = getViajesVacio();
  // Poblar mapa de lookup por índice
  window._COBRO_MAP = {};
  vacios.forEach((r, i) => { window._COBRO_MAP[i] = r; });

  // Cargar cobros ya registrados en Firestore
  let cobrosFirestore = [];
  let firestoreError = null;
  try {
    const snap = await getDocs(query(collection(db,'retiros_cobros'), orderBy('fecha','desc')));
    snap.forEach(d => cobrosFirestore.push({ id: d.id, ...d.data() }));
  } catch(e) {
    firestoreError = e.message;
    console.warn('Error cargando cobros:', e);
  }

  // ── KPIs de cobros ─────────────────────────────────────────────────────────
  const registradas  = new Set(cobrosFirestore.map(c => c.clave));

  const pendientes = vacios.reduce((acc, r, i) => {
    const clave = `${fmtDate(r.fecha)}_${r.cliente}_${r.conductor}`;
    if (!registradas.has(clave)) acc.push({ r, i, clave });
    return acc;
  }, []);

  const sinRegistrar = vacios.filter(r => {
    const clave = `${fmtDate(r.fecha)}_${r.cliente}_${r.conductor}`;
    return !registradas.has(clave);
  });
  const cobPend  = cobrosFirestore.filter(c => c.estado === 'Pendiente');
  const cobNotif = cobrosFirestore.filter(c => c.estado === 'Notificado');
  const cobCobr  = cobrosFirestore.filter(c => c.estado === 'Cobrado');
  const sumSinReg = sinRegistrar.reduce((s,r) => s + (r.tarifa||0), 0);
  const sumPend   = cobPend.reduce((s,c)  => s + (c.monto||0), 0);
  const sumNotif  = cobNotif.reduce((s,c) => s + (c.monto||0), 0);
  const sumCobr   = cobCobr.reduce((s,c)  => s + (c.monto||0), 0);

  cont.innerHTML = `
    <div style="display:grid;gap:20px">

      <!-- KPI cards resumen — funnel completo -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:12px">
        <div onclick="document.getElementById('cobros-sin-registrar').scrollIntoView({behavior:'smooth'})" style="background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #fca5a5;border-left:4px solid #dc2626;cursor:pointer;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 0 0 2px #dc262640'" onmouseout="this.style.boxShadow='none'">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;font-weight:600;margin-bottom:4px">🔴 Sin registrar</div>
          <div style="font-size:22px;font-weight:700;color:#dc2626">${sinRegistrar.length}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:2px">est. \$${sumSinReg.toLocaleString('es-CL')} <span style="font-size:10px;opacity:.6">↓ ver</span></div>
        </div>
        <div onclick="document.getElementById('cobros-pendiente').scrollIntoView({behavior:'smooth'})" style="background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e5e7eb;border-left:4px solid #f59e0b;cursor:pointer;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 0 0 2px #f59e0b40'" onmouseout="this.style.boxShadow='none'">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;font-weight:600;margin-bottom:4px">🟡 Por notificar</div>
          <div style="font-size:22px;font-weight:700;color:#b45309">${cobPend.length}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:2px">\$${sumPend.toLocaleString('es-CL')} <span style="font-size:10px;opacity:.6">↓ ver</span></div>
        </div>
        <div onclick="document.getElementById('cobros-notificados').scrollIntoView({behavior:'smooth'})" style="background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e5e7eb;border-left:4px solid #2563eb;cursor:pointer;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 0 0 2px #2563eb40'" onmouseout="this.style.boxShadow='none'">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;font-weight:600;margin-bottom:4px">🔵 Notificados</div>
          <div style="font-size:22px;font-weight:700;color:#1d4ed8">${cobNotif.length}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:2px">\$${sumNotif.toLocaleString('es-CL')} <span style="font-size:10px;opacity:.6">↓ ver</span></div>
        </div>
        <div onclick="document.getElementById('cobros-cobrados').scrollIntoView({behavior:'smooth'})" style="background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e5e7eb;border-left:4px solid #16a34a;cursor:pointer;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 0 0 2px #16a34a40'" onmouseout="this.style.boxShadow='none'">
          <div style="font-size:11px;color:#6b7280;text-transform:uppercase;font-weight:600;margin-bottom:4px">✅ Cobrados</div>
          <div style="font-size:22px;font-weight:700;color:#15803d">${cobCobr.length}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:2px">\$${sumCobr.toLocaleString('es-CL')} <span style="font-size:10px;opacity:.6">↓ ver</span></div>
        </div>
      </div>

      ${firestoreError ? `<div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:12px;color:#dc2626;font-size:13px">
        ⚠️ <strong>Firestore no disponible</strong> — Falta agregar la regla para <code>retiros_cobros</code> en Firebase Console.<br>
        <small>Los viajes en vacío detectados se muestran igual, pero no podrás guardar cobros hasta resolver esto.</small>
      </div>` : ''}
      <!-- Sección: pendientes de registrar -->
      <div class="tbl-card">
        <div class="tbl-title">
          <span>🚫 Viajes en vacío detectados — sin cobro registrado (${pendientes.length})</span>
        </div>
        ${pendientes.length === 0
          ? '<p style="padding:16px;color:#6b7280;font-size:13px">✅ Sin viajes en vacío pendientes de registrar.</p>'
          : `<table class="tbl">
              <thead><tr>
                <th>Fecha</th><th>Cliente</th><th>Conductor</th><th>Comuna</th><th>Tarifa ref.</th><th>Acción</th>
              </tr></thead>
              <tbody>${pendientes.map(({r, i}) => {
                return `<tr style="background:#fff7ed">
                  <td>${fmtDate(r.fecha)}</td>
                  <td><strong>${r.cliente}</strong></td>
                  <td>${r.conductor}</td>
                  <td>${r.comuna}</td>
                  <td>${fmtMoney(r.tarifa)}</td>
                  <td><button class="btn-sm" style="background:#f59e0b;color:#fff;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px"
                    onclick="abrirFormCobro(${i})">
                    💰 Registrar cobro
                  </button></td>
                </tr>`;
              }).join('')}</tbody>
            </table>`
        }
      </div>

      <!-- Sección: Por notificar (Pendiente) -->
      <div id="cobros-pendiente" class="tbl-card" style="scroll-margin-top:20px">
        <div class="tbl-title">
          <span>🟡 Por notificar — Pendiente (${cobPend.length})</span>
        </div>
        ${cobPend.length === 0
          ? '<p style="padding:16px;color:#6b7280;font-size:13px">Sin cobros pendientes de notificar.</p>'
          : `<table class="tbl">
              <thead><tr><th>Fecha</th><th>Cliente</th><th>Conductor</th><th>Monto</th><th>Motivo</th><th>Acción</th></tr></thead>
              <tbody>${cobPend.map(c => `<tr>
                <td>${c.fecha}</td>
                <td><strong>${c.cliente}</strong></td>
                <td>${c.conductor||'—'}</td>
                <td>${fmtMoney(c.monto)}</td>
                <td style="max-width:180px;font-size:12px">${c.motivo||'—'}</td>
                <td><button class="btn-sm" style="background:#f3f4f6;border:1px solid #d1d5db;border-radius:6px;padding:3px 8px;cursor:pointer;font-size:11px"
                  onclick="avanzarEstadoCobro('${c.id}','Notificado')">→ Notificado</button></td>
              </tr>`).join('')}</tbody>
            </table>`}
      </div>

      <!-- Sección: Notificados -->
      <div id="cobros-notificados" class="tbl-card" style="scroll-margin-top:20px">
        <div class="tbl-title">
          <span>🔵 Notificados (${cobNotif.length})</span>
        </div>
        ${cobNotif.length === 0
          ? '<p style="padding:16px;color:#6b7280;font-size:13px">Sin cobros notificados aún.</p>'
          : `<table class="tbl">
              <thead><tr><th>Fecha</th><th>Cliente</th><th>Conductor</th><th>Monto</th><th>Motivo</th><th>Acción</th></tr></thead>
              <tbody>${cobNotif.map(c => `<tr>
                <td>${c.fecha}</td>
                <td><strong>${c.cliente}</strong></td>
                <td>${c.conductor||'—'}</td>
                <td>${fmtMoney(c.monto)}</td>
                <td style="max-width:180px;font-size:12px">${c.motivo||'—'}</td>
                <td><button class="btn-sm" style="background:#f3f4f6;border:1px solid #d1d5db;border-radius:6px;padding:3px 8px;cursor:pointer;font-size:11px"
                  onclick="avanzarEstadoCobro('${c.id}','Cobrado')">→ Cobrado</button></td>
              </tr>`).join('')}</tbody>
            </table>`}
      </div>

      <!-- Sección: Cobrados -->
      <div id="cobros-cobrados" class="tbl-card" style="scroll-margin-top:20px">
        <div class="tbl-title">
          <span>✅ Cobrados (${cobCobr.length})</span>
        </div>
        ${cobCobr.length === 0
          ? '<p style="padding:16px;color:#6b7280;font-size:13px">Sin cobros marcados como cobrados aún.</p>'
          : `<table class="tbl">
              <thead><tr><th>Fecha</th><th>Cliente</th><th>Conductor</th><th>Monto</th><th>Motivo</th><th>Estado</th></tr></thead>
              <tbody>${cobCobr.map(c => `<tr>
                <td>${c.fecha}</td>
                <td><strong>${c.cliente}</strong></td>
                <td>${c.conductor||'—'}</td>
                <td style="font-weight:600;color:#15803d">${fmtMoney(c.monto)}</td>
                <td style="max-width:180px;font-size:12px">${c.motivo||'—'}</td>
                <td>✅</td>
              </tr>`).join('')}</tbody>
            </table>`}
      </div>
    </div>
  `;
};

// Modal cobro
window.abrirFormCobro = (idx) => {
  const r = window._COBRO_MAP[idx];
  if (!r) { alert('Error: registro no encontrado.'); return; }
  const cliente    = r.cliente;
  const conductor  = r.conductor;
  const fecha      = fmtDate(r.fecha);
  const tarifaRef  = r.tarifa;
  const clave      = `${fecha}_${cliente}_${conductor}`;
  const monto = tarifaRef > 0 ? tarifaRef : 3500;
  const html = `
    <div id="modal-cobro" style="position:fixed;inset:0;background:#0008;z-index:9999;display:flex;align-items:center;justify-content:center">
      <div style="background:#fff;border-radius:12px;padding:28px;width:400px;box-shadow:0 20px 60px #0003">
        <h3 style="font-size:15px;font-weight:700;margin-bottom:16px">💰 Registrar cobro — Viaje en vacío</h3>
        <div style="display:grid;gap:10px;font-size:13px">
          <div><strong>Cliente:</strong> ${cliente}</div>
          <div><strong>Fecha:</strong> ${fecha}</div>
          <div><strong>Conductor:</strong> ${conductor}</div>
          <label>Monto a cobrar ($)
            <input id="cobro-monto" type="number" value="${monto}" min="0"
              style="width:100%;margin-top:4px;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:14px">
          </label>
          <label>Motivo / notas
            <textarea id="cobro-motivo" rows="2" placeholder="Ej: Viaje en vacío, cliente no avisó cancelación"
              style="width:100%;margin-top:4px;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;resize:vertical">Viaje en vacío — cliente no avisó que no tenía paquetería.</textarea>
          </label>
        </div>
        <div style="display:flex;gap:8px;margin-top:18px;justify-content:flex-end">
          <button onclick="document.getElementById('modal-cobro').remove()"
            style="padding:8px 16px;border:1px solid #d1d5db;border-radius:6px;background:#fff;cursor:pointer">Cancelar</button>
          <button onclick="guardarCobro()"
            style="padding:8px 16px;background:#f59e0b;color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:600">💾 Guardar</button>
        </div>
      </div>
    </div>`;
  window._pendingCobro = { cliente, conductor, fecha, clave };
  document.body.insertAdjacentHTML('beforeend', html);
};

window.guardarCobro = async () => {
  const { cliente, conductor, fecha, clave } = window._pendingCobro || {};
  if (!cliente) { alert('Error: datos no disponibles.'); return; }
  const monto  = parseFloat(document.getElementById('cobro-monto').value) || 0;
  const motivo = document.getElementById('cobro-motivo').value.trim();
  if (!monto) { alert('Ingresa un monto válido.'); return; }

  try {
    await addDoc(collection(db, 'retiros_cobros'), {
      cliente, conductor, fecha, clave,
      monto, motivo,
      estado:     'Pendiente',
      creado_por: window._currentUser?.email || 'sistema',
      creado_en:  serverTimestamp(),
    });
    document.getElementById('modal-cobro')?.remove();
    await renderCobros();
  } catch(e) {
    alert('❌ Error guardando cobro:\n' + e.message + '\n\nVerifica que la regla de Firestore para retiros_cobros esté activa.');
  }
};

window.avanzarEstadoCobro = async (id, nuevoEstado) => {
  try {
    await setDoc(doc(db, 'retiros_cobros', id), { estado: nuevoEstado }, { merge: true });
    await renderCobros();
  } catch(e) {
    alert('Error: ' + e.message);
  }
};

window.showTab = name => {
  document.querySelectorAll('.tab').forEach((t,i)=>{
    const n=['dashboard','chofer','comunas','clientes','tiempos','detalle','cobros','historial'][i];
    t.classList.toggle('active', n===name);
  });
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const panel = document.getElementById('tab-'+name);
  if (panel) panel.classList.add('active');
  if (name === 'cobros') renderCobros();
};

window.showSection = showSection;
</script>
</div><!-- /app -->
</body>
</html>
